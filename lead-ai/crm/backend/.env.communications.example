# ==================== COMMUNICATION INTEGRATIONS CONFIGURATION ====================
# Set up your API keys and credentials for WhatsApp, Email, and Call integrations

# -------------------- WhatsApp Integration --------------------
# Choose provider: 'twilio' or 'meta' (Meta WhatsApp Business Cloud API)
WHATSAPP_PROVIDER=twilio

# Option 1: Twilio WhatsApp API (Easiest to get started)
# Sign up at: https://www.twilio.com/
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886  # Twilio Sandbox number
TWILIO_PHONE_NUMBER=+1234567890  # For voice calls

# Option 2: Meta WhatsApp Business Cloud API (Production-ready)
# Sign up at: https://developers.facebook.com/docs/whatsapp/cloud-api
META_WHATSAPP_ACCESS_TOKEN=your_meta_access_token_here
META_WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
META_WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id_here

# Webhook callback URL (your server URL for receiving messages)
TWILIO_CALLBACK_URL=https://your-domain.com

# -------------------- Email Integration --------------------
# Choose provider: 'smtp' or 'sendgrid'
EMAIL_PROVIDER=smtp

# Option 1: SMTP (Gmail, Outlook, etc.)
# Gmail: Enable "App Passwords" in your Google Account settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com

# Option 2: SendGrid (Recommended for production)
# Sign up at: https://sendgrid.com/
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# -------------------- Database Configuration --------------------
# Already configured in your existing .env
# USE_SUPABASE=true
# SUPABASE_URL=your_supabase_url
# SUPABASE_KEY=your_supabase_key


# ==================== SETUP INSTRUCTIONS ====================

# 1. TWILIO WHATSAPP (Free Sandbox - Quickest Setup)
#    - Go to https://console.twilio.com/
#    - Create free account
#    - Navigate to Messaging > Try it out > Send a WhatsApp message
#    - Copy Account SID and Auth Token
#    - Use sandbox number: whatsapp:+14155238886
#    - To connect your phone: Send "join <sandbox-keyword>" to the sandbox number
#    - Cost: Free for testing, $0.005 per message in production

# 2. TWILIO VOICE CALLS WITH RECORDING
#    - Same Twilio account as above
#    - Buy a phone number ($1/month): https://console.twilio.com/phone-numbers
#    - Call recording is automatically enabled
#    - Recordings stored for 30 days (can download to your server)
#    - Cost: $0.013/min for US calls

# 3. META WHATSAPP BUSINESS CLOUD API (Production)
#    - Go to https://developers.facebook.com/
#    - Create App > Business > WhatsApp
#    - Add phone number and verify business
#    - Get Access Token and Phone Number ID
#    - Configure webhook URL for receiving messages
#    - Cost: Free for first 1,000 conversations/month

# 4. GMAIL SMTP (For Email)
#    - Use your Gmail account
#    - Enable 2-Factor Authentication
#    - Create App Password: https://myaccount.google.com/apppasswords
#    - Use app password in SMTP_PASSWORD
#    - Cost: Free

# 5. SENDGRID (Production Email)
#    - Sign up at https://sendgrid.com/
#    - Free tier: 100 emails/day
#    - Create API key in Settings > API Keys
#    - Verify sender email address
#    - Cost: Free for 100/day, $14.95/month for 40k emails


# ==================== WEBHOOK CONFIGURATION ====================

# For receiving WhatsApp messages and call status updates:
# 1. Deploy your backend to a public URL (use ngrok for local testing)
# 2. Configure webhooks in Twilio console:
#    - WhatsApp: https://your-domain.com/api/communications/whatsapp/webhook
#    - Voice Calls: https://your-domain.com/api/communications/call/recording-complete

# Using ngrok for local development:
# - Download: https://ngrok.com/download
# - Run: ngrok http 8000
# - Copy the https URL (e.g., https://abc123.ngrok.io)
# - Add to .env: TWILIO_CALLBACK_URL=https://abc123.ngrok.io


# ==================== ML TRAINING DATA STORAGE ====================

# All communications are automatically stored in the database for:
# 1. Chat history display in UI
# 2. ML model training (sentiment analysis, response generation)
# 3. Quality assurance and compliance
# 4. Performance analytics

# Database table: communication_history
# Fields:
#   - lead_id: Link to lead
#   - communication_type: whatsapp, email, call
#   - direction: inbound, outbound
#   - content: Message text or call transcript
#   - timestamp: When it happened
#   - status: sent, delivered, read, failed
#   - metadata: JSON with recording URLs, durations, etc.
#   - used_for_training: Boolean flag for ML training dataset


# ==================== RECOMMENDED SETUP FOR BEGINNERS ====================

# Step 1: Start with Twilio (easiest)
#   WHATSAPP_PROVIDER=twilio
#   TWILIO_ACCOUNT_SID=<from Twilio console>
#   TWILIO_AUTH_TOKEN=<from Twilio console>
#   TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
#   TWILIO_PHONE_NUMBER=<buy one for $1/month>

# Step 2: Use Gmail SMTP for email
#   EMAIL_PROVIDER=smtp
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USERNAME=<your-gmail>
#   SMTP_PASSWORD=<app-password>
#   SMTP_FROM_EMAIL=<your-gmail>

# Step 3: Run backend with new endpoints
#   cd backend
#   pip install twilio sendgrid
#   python main.py

# Step 4: Test in LeadsPage
#   - Click WhatsApp icon to open chat
#   - Click Phone icon to make a call
#   - Click Email icon to send email
#   - All history stored automatically


# ==================== PRODUCTION CHECKLIST ====================

# ✅ Move from Twilio Sandbox to approved WhatsApp Business Account
# ✅ Buy dedicated phone number for calls ($1-2/month)
# ✅ Set up proper webhook URLs (not ngrok)
# ✅ Configure SendGrid for reliable email delivery
# ✅ Enable SSL/HTTPS on your domain
# ✅ Set up monitoring for failed messages
# ✅ Implement rate limiting to prevent abuse
# ✅ Add authentication to webhook endpoints
# ✅ Set up automated backup of recordings
# ✅ Comply with GDPR/privacy laws for recordings


# ==================== COSTS BREAKDOWN ====================

# Twilio WhatsApp:
